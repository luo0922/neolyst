# Stock Quote Sync Configuration
# This file contains the schedule settings for the stock quote sync task

# Schedule configuration
# Format: CRON_EXPRESSION = Description
# Common examples:
# 0 6 * * * = Every day at 6:00 AM
# 0 6 * * 1-5 = Every weekday at 6:00 AM
# 0 6 * * 0,6 = Every weekend at 6:00 AM
# 0 0 * * * = Every day at midnight
# 0 */4 * * * = Every 4 hours

# Default schedule: Every day at 6:00 AM
SYNC_SCHEDULE="0 6 * * *"

# Sync options
# Whether to fetch 1 year history on first run
FETCH_INITIAL_HISTORY=true

# Delay between API calls (ms) to avoid rate limiting
API_DELAY_MS=300

# Log file path (optional)
# LOG_FILE="/var/log/stock-quotes-sync.log"
